# Copy to .env and fill in. Leave Supabase blank to use in-memory demo catalog.
SUPABASE_URL=
SUPABASE_KEY=
# Optional: enables LangChain structured parsing + richer summaries
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Comma-separated origins for CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
